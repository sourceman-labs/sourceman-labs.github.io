@page "/projects/{slug}"
@attribute [RenderStatic]
@model ProjectDetailModel
@inject MarkdownProjects Projects
@{
    var project = Projects.FindProjectBySlug(Model.Slug!);

    if (project == null)
    {
        Response.StatusCode = 404;
        return;
    }

    ViewData["Title"] = project.Title;
    ViewData["Description"] = project.Summary ?? project.Title;
    ViewData["CanonicalUrl"] = $"https://www.sourceman.se{Projects.GetProjectLink(project)}";
    ViewData["UseSyntaxHighlighting"] = true;
    Layout = "_Layout";
}

<article class="project-detail content-narrow">
    <header class="post-header">
        <h1 class="post-title">@project.Title</h1>

        @if (!string.IsNullOrEmpty(project.Url))
        {
            <p class="project-repo-link">
                <a href="@project.Url" target="_blank" rel="noopener noreferrer">View on GitHub →</a>
            </p>
        }

        @if (project.Tags.Any())
        {
            <div class="post-tags">
                @foreach (var tag in project.Tags)
                {
                    <a href="@Projects.GetTagLink(tag)" class="tag">#@tag</a>
                }
            </div>
        }
    </header>

    @if (!string.IsNullOrEmpty(project.Summary))
    {
        <div class="post-excerpt">
            <p>@project.Summary</p>
        </div>
    }

    <div class="post-content">
        @Html.Raw(project.Preview)
    </div>
</article>

@using ServiceStack
@using ServiceStack.Mvc
@using Sourceman.Web.Pages
@implements ServiceStack.Mvc.IRenderStatic<Sourceman.Web.Pages.ProjectDetailModel>

@functions {
    public List<ProjectDetailModel> GetStaticProps(RenderContext ctx)
    {
        var projects = ctx.Resolve<MarkdownProjects>();
        return projects.GetProjects().Map(doc => new ProjectDetailModel { Slug = doc.Slug });
    }
}
