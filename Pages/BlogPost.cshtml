@page "/blog/{slug}"
@attribute [RenderStatic]
@model BlogPostModel
@inject MarkdownBlog Blog
@{
    var post = Blog.FindPostBySlug(Model.Slug!);

    if (post == null)
    {
        Response.StatusCode = 404;
        return;
    }

    ViewData["Title"] = post.Title;
    ViewData["Description"] = post.Summary ?? post.Title;
    ViewData["OgType"] = "article";
    ViewData["CanonicalUrl"] = $"https://sourceman.se{Blog.GetPostLink(post)}";
    Layout = "_Layout";
}

<article class="blog-post content-narrow">
    <header class="post-header">
        <h1 class="post-title">@post.Title</h1>

        <div class="post-meta">
            <time datetime="@post.Date?.ToString("o")" class="post-date">
                @Blog.GetDateLabel(post.Date)
            </time>

            @if (post.ReadingTime > 0)
            {
                <span class="separator">•</span>
                <span class="post-reading-time">@post.ReadingTime min read</span>
            }

            @if (post.Author != null)
            {
                <span class="separator">•</span>
                <span class="post-author">@post.Author</span>
            }
        </div>

        @if (post.Tags.Any())
        {
            <div class="post-tags">
                @foreach (var tag in post.Tags)
                {
                    <a href="@Blog.GetTagLink(tag)" class="tag">#@tag</a>
                }
            </div>
        }
    </header>

    @if (!string.IsNullOrEmpty(post.Summary))
    {
        <div class="post-excerpt">
            <p>@post.Summary</p>
        </div>
    }

    <div class="post-content">
        @Html.Raw(post.Preview)
    </div>

    @if (post.Date != null && post.Date.Value.AddDays(1) < DateTime.UtcNow)
    {
        <footer class="post-footer">
            <p class="post-published">
                Published: <time datetime="@post.Date?.ToString("o")">
                    @Blog.GetDateLabel(post.Date)
                </time>
            </p>
        </footer>
    }
</article>

@implements IRenderStatic<BlogPostModel>

@functions {
    public List<BlogPostModel> GetStaticProps(RenderContext ctx)
    {
        var blog = ctx.Resolve<MarkdownBlog>();
        return blog.GetPosts().Map(doc => new BlogPostModel { Slug = doc.Slug });
    }
}
